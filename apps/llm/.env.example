# Upstage Solar — https://console.upstage.ai/
# UPSTAGE_API_KEY 가 있으면 (기본) explain은 Solar → GEMINI_MODEL 변경은 적용 안 됨
UPSTAGE_API_KEY=
SOLAR_MODEL=solar-pro2
SOLAR_TEMPERATURE=0.65

# Google AI Studio — Solar 없을 때 또는 LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# auto(기본) | solar | gemini
LLM_PROVIDER=auto

LLM_TIMEOUT_SECONDS=60
